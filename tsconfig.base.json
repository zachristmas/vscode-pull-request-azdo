{
	"compilerOptions": {
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"incremental": true,
		"isolatedModules": false,
		// Runtime is VS Code >=1.97 (Node 20 / Chrome 128); es2023 lib matches what actually ships (toSorted etc).
		"lib": ["es2023"],
		"module": "esnext",
		// node10 resolution is deprecated and gone in TS 7; moving to "bundler" (extension/webviews)
		// + "node16" (tests) is its own migration, deferred until the TS 7 jump.
		"ignoreDeprecations": "6.0",
		"moduleResolution": "node",
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": false,
		"noUnusedLocals": false,
		"outDir": "dist",
		"resolveJsonModule": true,
		"rootDir": ".",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es2019",
		"useDefineForClassFields": true,
		"allowSyntheticDefaultImports": true,
		"typeRoots": ["./node_modules/@types", "./src/@types"]
	},
	"include": ["src/**/*", "webviews/**/*"],
	"exclude": ["node_modules", ".vscode-test"]
}
